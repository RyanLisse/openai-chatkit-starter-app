# OpenAI/Anthropic API Keys
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-...

# ChatKit Configuration (Optional - for ChatKit integration)
NEXT_PUBLIC_CHATKIT_WORKFLOW_ID=wf_...
CHATKIT_API_BASE=https://api.openai.com

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/sniping_bot

# MEXC API Configuration (for testing only - users will add their own via UI)
MEXC_API_KEY=your_mexc_api_key
MEXC_SECRET_KEY=your_mexc_secret_key
MEXC_TESTNET=false

# NextAuth Configuration (if implementing authentication)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_generate_with_openssl

# Bot Configuration Defaults
DEFAULT_MAX_TRADE_AMOUNT=100
DEFAULT_MIN_TRADE_AMOUNT=10
DEFAULT_STOP_LOSS_PERCENTAGE=5
DEFAULT_TAKE_PROFIT_PERCENTAGE=10
DEFAULT_MAX_DAILY_TRADES=20
DEFAULT_MAX_CONCURRENT_TRADES=3
DEFAULT_AI_CONFIDENCE_THRESHOLD=0.75

# Redis (Optional - for production bot state management)
REDIS_URL=redis://localhost:6379

# Application Settings
NODE_ENV=development
LOG_LEVEL=info
